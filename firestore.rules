rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in [
          "psico.klo@gmail.com",
          "terapiaconkimberlylopez@gmail.com",
          "angel.abarzua15@gmail.com"
        ];
    }

    function hasActiveDiscount(serviceData) {
      return serviceData.discountEnabled == true
        && serviceData.discountPrice > 0
        && serviceData.discountPrice < serviceData.price
        && request.time <= serviceData.discountEndsAt;
    }

    function validPublishedService(data) {
      let serviceData = get(/databases/$(database)/documents/services/$(data.servicio)).data;
      return serviceData.active == true
        && data.servicioLabel == serviceData.bookingLabel
        && (
          (hasActiveDiscount(serviceData)
            && data.servicioValor == serviceData.discountPriceLabel)
          || (!hasActiveDiscount(serviceData)
            && data.servicioValor == serviceData.priceLabel)
        );
    }

    function validService(data) {
      return exists(/databases/$(database)/documents/services/$(data.servicio))
        && validPublishedService(data);
    }

    function validServiceDocument(serviceId) {
      let data = request.resource.data;
      return data.keys().hasOnly([
          "id",
          "title",
          "meta",
          "description",
          "bookingLabel",
          "price",
          "priceLabel",
          "icon",
          "order",
          "active",
          "discountEnabled",
          "discountPrice",
          "discountPriceLabel",
          "discountEndsAt",
          "createdAt",
          "updatedAt"
        ])
        && data.keys().hasAll([
          "id",
          "title",
          "meta",
          "description",
          "bookingLabel",
          "price",
          "priceLabel",
          "icon",
          "order",
          "active",
          "discountEnabled",
          "discountPrice",
          "discountPriceLabel",
          "discountEndsAt",
          "createdAt",
          "updatedAt"
        ])
        && data.id == serviceId
        && data.title is string
        && data.title.size() >= 3
        && data.title.size() <= 100
        && data.meta is string
        && data.meta.size() <= 60
        && data.description is string
        && data.description.size() >= 10
        && data.description.size() <= 300
        && data.bookingLabel is string
        && data.bookingLabel.size() >= 3
        && data.bookingLabel.size() <= 170
        && data.price is int
        && data.price >= 1000
        && data.price <= 10000000
        && data.priceLabel is string
        && data.priceLabel.size() >= 2
        && data.priceLabel.size() <= 30
        && data.icon in [
          "sparkles", "heart", "brain", "people", "child", "home", "clipboard",
          "video", "calendar", "message", "support", "couple", "family", "shield",
          "medical", "activity", "smile", "moon", "sun", "puzzle", "book",
          "education", "nature"
        ]
        && data.order is int
        && data.order >= 1
        && data.order <= 999
        && data.active is bool
        && data.discountEnabled is bool
        && data.discountPrice is int
        && data.discountPrice >= 0
        && data.discountPrice < data.price
        && data.discountPriceLabel is string
        && data.discountPriceLabel.size() >= 2
        && data.discountPriceLabel.size() <= 30
        && data.discountEndsAt is timestamp
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && (
          data.discountEnabled == false
          || (data.discountPrice > 0 && data.discountEndsAt > request.time)
        );
    }

    function validSlotId(slotId, date, time) {
      return (time == "09:00" && slotId == date + "_0900")
        || (time == "10:00" && slotId == date + "_1000")
        || (time == "11:00" && slotId == date + "_1100")
        || (time == "12:00" && slotId == date + "_1200")
        || (time == "13:00" && slotId == date + "_1300")
        || (time == "14:00" && slotId == date + "_1400")
        || (time == "15:00" && slotId == date + "_1500")
        || (time == "16:00" && slotId == date + "_1600")
        || (time == "17:00" && slotId == date + "_1700")
        || (time == "18:00" && slotId == date + "_1800")
        || (time == "19:00" && slotId == date + "_1900")
        || (time == "20:00" && slotId == date + "_2000")
        || (time == "21:00" && slotId == date + "_2100");
    }

    function slotIsPublished(date, time) {
      // Compatibilidad durante la migración: se conserva el horario anterior solo
      // hasta que el panel publique por primera vez la configuración dinámica.
      return !exists(/databases/$(database)/documents/availability_settings/default)
        || (
          exists(/databases/$(database)/documents/availability_calendar/$(date))
          && get(/databases/$(database)/documents/availability_calendar/$(date)).data.fecha == date
          && time in get(/databases/$(database)/documents/availability_calendar/$(date)).data.availableTimes
        );
    }

    function validPublicAppointment(slotId) {
      return request.resource.data.keys().hasOnly([
          "nombre",
          "apellido",
          "edad",
          "rut",
          "telefono",
          "email",
          "servicio",
          "servicioLabel",
          "servicioValor",
          "motivo",
          "fecha",
          "hora",
          "createdAt",
          "estado"
        ])
        && request.resource.data.nombre is string
        && request.resource.data.nombre.size() >= 2
        && request.resource.data.nombre.size() <= 80
        && request.resource.data.apellido is string
        && request.resource.data.apellido.size() >= 2
        && request.resource.data.apellido.size() <= 80
        && request.resource.data.edad is int
        && request.resource.data.edad >= 1
        && request.resource.data.edad <= 120
        && request.resource.data.rut is string
        && request.resource.data.rut.size() >= 7
        && request.resource.data.rut.size() <= 16
        && request.resource.data.rut.matches('^[0-9.kK-]+$')
        && request.resource.data.email is string
        && request.resource.data.email.size() >= 5
        && request.resource.data.email.size() <= 160
        && request.resource.data.email.matches('^[^@ ]+@[^@ ]+\\.[^@ ]+$')
        && request.resource.data.telefono is string
        && request.resource.data.telefono.size() >= 8
        && request.resource.data.telefono.size() <= 30
        && request.resource.data.servicio is string
        && request.resource.data.servicio.size() >= 1
        && request.resource.data.servicio.size() <= 128
        && request.resource.data.servicioLabel is string
        && request.resource.data.servicioLabel.size() >= 3
        && request.resource.data.servicioLabel.size() <= 170
        && request.resource.data.servicioValor is string
        && request.resource.data.servicioValor.size() >= 2
        && request.resource.data.servicioValor.size() <= 30
        && validService(request.resource.data)
        && request.resource.data.motivo is string
        && request.resource.data.motivo.size() <= 1500
        && request.resource.data.fecha is string
        && request.resource.data.fecha.size() == 10
        && request.resource.data.fecha.matches('^20[0-9]{2}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])$')
        && request.resource.data.hora is string
        && request.resource.data.hora.size() == 5
        && validSlotId(slotId, request.resource.data.fecha, request.resource.data.hora)
        && slotIsPublished(request.resource.data.fecha, request.resource.data.hora)
        && request.resource.data.createdAt == request.time
        && request.resource.data.estado == "confirmada"
        && existsAfter(/databases/$(database)/documents/availability_blocks/$(slotId))
        && getAfter(/databases/$(database)/documents/availability_blocks/$(slotId)).data.fecha == request.resource.data.fecha
        && getAfter(/databases/$(database)/documents/availability_blocks/$(slotId)).data.hora == request.resource.data.hora;
    }

    function validAvailabilityBlock(slotId) {
      return request.resource.data.keys().hasOnly([
          "fecha",
          "hora",
          "tipo",
          "createdAt"
        ])
        && request.resource.data.fecha is string
        && request.resource.data.fecha.size() == 10
        && request.resource.data.fecha.matches('^20[0-9]{2}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])$')
        && request.resource.data.hora is string
        && request.resource.data.hora.size() == 5
        && validSlotId(slotId, request.resource.data.fecha, request.resource.data.hora)
        && slotIsPublished(request.resource.data.fecha, request.resource.data.hora)
        && request.resource.data.tipo == "sesion"
        && request.resource.data.createdAt == request.time
        && existsAfter(/databases/$(database)/documents/appointments/$(slotId))
        && getAfter(/databases/$(database)/documents/appointments/$(slotId)).data.fecha == request.resource.data.fecha
        && getAfter(/databases/$(database)/documents/appointments/$(slotId)).data.hora == request.resource.data.hora;
    }

    match /availability_blocks/{slotId} {
      allow read: if true;
      allow create: if isAdmin() || validAvailabilityBlock(slotId);
      allow update, delete: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow read, update, delete: if isAdmin();
      allow create: if isAdmin() || validPublicAppointment(appointmentId);
    }

    match /availability_settings/{settingId} {
      allow get: if settingId == "default";
      allow list: if isAdmin();
      allow write: if isAdmin() && settingId == "default";
    }

    match /availability_calendar/{date} {
      // El cliente público no necesita enumerar el calendario materializado.
      // Las reglas pueden consultarlo internamente para validar una reserva.
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create, update: if isAdmin() && validServiceDocument(serviceId);
      allow delete: if isAdmin();
    }

    match /service_settings/{settingId} {
      allow get: if settingId == "default";
      allow list: if isAdmin();
      allow create, update: if isAdmin()
        && settingId == "default"
        && request.resource.data.keys().hasOnly(["initialized", "version", "updatedAt"])
        && request.resource.data.initialized == true
        && request.resource.data.version is int
        && request.resource.data.version >= 1
        && request.resource.data.updatedAt is timestamp;
      allow delete: if false;
    }

    match /patients/{document=**} {
      allow read, write: if isAdmin();
    }

    match /sessions/{document=**} {
      allow read, write: if isAdmin();
    }

    match /quick_notes/{document=**} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
